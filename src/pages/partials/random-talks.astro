---
export const partial = true;
import StarringCard from "@/components/home/StarringCard.astro";
import { getRandomTalks } from "@/lib/talks";

const starred = await getRandomTalks();
---

{
  starred.map((talk) => (
    <StarringCard
      talkId={talk.id}
      title={talk.title}
      speakers={talk.speakers}
      typeName={talk.typeName}
    />
  ))
}
