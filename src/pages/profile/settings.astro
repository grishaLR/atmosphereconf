---
import Layout from "../../layouts/Layout.astro";
import Card from "@/components/ui/card.astro";
import { ProfileSettingsForm } from "@/components/profile/ProfileSettingsForm";
import { maybeGetLoggedInProfile } from "@/lib/profile";

const profile = await maybeGetLoggedInProfile({
  locals: Astro.locals,
  type: "full",
});

if (!profile) {
  return Astro.redirect("/login");
}

const confProfile = profile.confProfile;
const settingsProps = {
  initialValues: {
    displayName: confProfile?.displayName || profile.displayName || "",
    description: confProfile?.description || "",
    interests: confProfile?.interests?.join(", ") || "",
  },
  initialLocation: confProfile?.homeTown
    ? { name: confProfile.homeTown.name, h3Index: confProfile.homeTown.value }
    : null,
  currentAvatarUrl: profile.avatarUrl || null,
  existingAvatarBlob: confProfile?.avatar
    ? { ...confProfile.avatar, $type: "blob" as const }
    : null,
};
---

<Layout title="Edit Profile - Atmosphere Conference">
  <div class="w-full px-4">
    <Card class="max-w-2xl mx-auto mt-8 p-8">
      <ProfileSettingsForm client:load {...settingsProps} />
    </Card>
  </div>
</Layout>
