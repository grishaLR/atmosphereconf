---
import Layout from "../../layouts/Layout.astro";
import Card from "@/components/ui/card.astro";
import { ProfileView } from "@/components/profile/ProfileView";
import { loadProfile } from "@/lib/profile";
import { getActiveIcons } from "@/components/profile/lexicon-icons";

const { loggedInUser } = Astro.locals;
if (!loggedInUser) return Astro.redirect("/login");

const profile = await loadProfile(loggedInUser.did);
if (!profile) return Astro.redirect("/login");

const svgFiles = import.meta.glob<string>("/src/components/profile/icons/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
});
const svgMap: Record<string, string> = Object.fromEntries(
  Object.entries(svgFiles).map(([path, svg]) => [
    path.replace(/.*\//, "").replace(".svg", ""),
    svg,
  ])
);

const activeIcons = getActiveIcons(profile.collections).map((icon) => ({
  label: icon.label,
  html: svgMap[icon.svgName] ?? "",
  href: icon.url?.(profile.handle, profile.did),
}));

const editData = {
  initialDisplayName: profile.displayName,
  initialDescription: profile.description || "",
  initialBio: profile.bio || "",
  initialInterests: profile.interests?.join(", ") || "",
  initialPronouns: profile.pronouns || "",
  initialWebsite: profile.website || "",
  initialLocation: profile.homeTown?.value
    ? { name: profile.homeTown.name ?? "", h3Index: profile.homeTown.value }
    : null,
  currentAvatarUrl: profile.avatarUrl || null,
  existingAvatarBlob: profile.confAvatarBlob,
};
---

<Layout title="Profile - Atmosphere Conference">
  <div class="w-full">
    <Card class="max-w-2xl mx-auto mt-8 p-8">
      <ProfileView
        client:load
        {...profile}
        isOwnProfile={true}
        activeIcons={activeIcons}
        editData={editData}
      />
    </Card>
  </div>
</Layout>
